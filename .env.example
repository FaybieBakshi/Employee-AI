# ─────────────────────────────────────────────────────
# AI Employee — Environment Variables (Gold Tier)
# Copy to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────

# Path to your Obsidian vault
VAULT_PATH=AI_Employee_Vault

# Dry-run mode: "true" = log actions without executing (start here!)
DRY_RUN=true

# ─── Orchestrator ──────────────────────────────────────
# Comma-separated list of watchers to start: fs, gmail, approval, whatsapp
ORCHESTRATOR_WATCHERS=fs,approval
# Set to "true" to enable Gmail watcher automatically
ENABLE_GMAIL=false
# Set to "true" to enable WhatsApp watcher
ENABLE_WHATSAPP=false

# ─── Gmail Watcher ──────────────────────────────────────
GMAIL_CREDENTIALS_PATH=credentials/gmail_credentials.json
GMAIL_TOKEN_PATH=credentials/gmail_token.json
GMAIL_CHECK_INTERVAL=120
GMAIL_QUERY=is:unread is:important

# ─── Email MCP (SMTP) ───────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
# Use a Gmail App Password (NOT your main password):
# myaccount.google.com/apppasswords → Generate → Mail
SMTP_PASSWORD=your_app_password_here

# ─── LinkedIn ────────────────────────────────────────────
LINKEDIN_BUSINESS=My Business
LINKEDIN_INDUSTRY=business consulting
LINKEDIN_TONE=professional

# ─── WhatsApp (Gold Tier) ─────────────────────────────────
WHATSAPP_SESSION_PATH=.whatsapp_session
WHATSAPP_CHECK_INTERVAL=300

# ─── Facebook / Instagram (Gold Tier) ────────────────────
# Get Page Access Token from Meta for Developers:
# developers.facebook.com → Your App → Graph API Explorer
FB_PAGE_ID=your_page_id
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_token

# Instagram Business Account (linked to your Facebook Page)
IG_ACCOUNT_ID=your_instagram_business_id

# ─── Twitter / X (Gold Tier) ─────────────────────────────
# Create app at developer.twitter.com → Projects & Apps
# Requires "Read and Write" permission
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_token_secret

# ─── Odoo Community (Gold Tier) ──────────────────────────
# Your Odoo instance URL and credentials
ODOO_URL=http://localhost:8069
ODOO_DB=your_database_name
ODOO_USER=admin@example.com
ODOO_PASSWORD=your_odoo_password

# ─── Scheduler ───────────────────────────────────────────
DAILY_BRIEFING_TIME=08:00
CEO_BRIEFING_DAY=monday
LINKEDIN_POST_DAY=sunday
LINKEDIN_POST_TIME=20:00
WEEKLY_AUDIT_TIME=08:00

# ─── Ralph Wiggum Loop (Gold Tier) ───────────────────────
RALPH_MAX_ITERATIONS=10
